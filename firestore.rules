rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Voter sessions: users can only read/write their own session
    match /voter_sessions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['tasks', 'updatedAt'])
        && request.resource.data.tasks is list
        && request.resource.data.tasks.size() <= 10;
    }

    // Analytics events: write-only, validated structure
    match /analytics_events/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['eventName', 'timestamp'])
        && request.resource.data.eventName is string
        && request.resource.data.eventName.size() <= 100;
      allow read: if false;
    }

    // Crowd telemetry: read-only for authenticated users
    match /crowd_telemetry/{boothId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
